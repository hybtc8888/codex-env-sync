{
  "name": "@hybtc8888/codex-env-sync",
  "version": "0.4.6",
  "description": "Safely sync Codex settings between Windows and macOS without syncing account auth.",
  "license": "MIT",
  "author": "hybtc8888 <hybtc8888@gmail.com>",
  "homepage": "https://github.com/hybtc8888/codex-env-sync#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hybtc8888/codex-env-sync.git"
  },
  "main": "src/electron-main.js",
  "bin": {
    "codex-env-sync": "src/cli.js"
  },
  "scripts": {
    "start": "electron .",
    "check": "node src/cli.js check",
    "test": "node --test tests/core.test.js tests/i18n.test.js tests/github-auth.test.js tests/resilience.test.js tests/security.test.js",
    "package:win": "electron-builder --win --x64 --publish never",
    "package:win:x64": "electron-builder --win --x64 --publish never",
    "package:win:arm64": "electron-builder --win --arm64 --publish never",
    "package:win:all": "electron-builder --win --x64 --arm64 --publish never",
    "package:mac": "electron-builder --mac --x64 --arm64 --publish never",
    "package:all": "electron-builder --win --mac --x64 --arm64 --publish never"
  },
  "files": [
    "src",
    "scripts",
    "examples",
    "README.md",
    "README.zh-CN.md",
    "LICENSE"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "devDependencies": {
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.hybtc8888.codexenvsync",
    "productName": "Codex Env Sync",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "package.json",
      "examples/**/*",
      "README.md",
      "README.zh-CN.md",
      "LICENSE"
    ],
    "win": {
      "artifactName": "Codex.Env.Sync.${version}-${arch}.${ext}",
      "signAndEditExecutable": false,
      "target": [
        "portable",
        "zip"
      ]
    },
    "mac": {
      "identity": "-",
      "hardenedRuntime": false,
      "target": [
        "dmg"
      ],
      "category": "public.app-category.developer-tools"
    }
  }
}
